---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoCard from '../components/PhotoCard.astro';
---

<BaseLayout>
    <div class="eventos">
        <div class="title">
            <h2>Eventos</h2>
        </div>
        <div class="gallery">
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/alwaysrush.jpg`} alt="Always in a Rush" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/guilhermeGrade.jpg`} alt="Guilherme Collection" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/senhorFonte.jpg`} alt="Senhor Fonte" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/protestoEstudantebw.jpg`} alt="Manifestação Estudante 2026" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/duoRiso.jpg`} alt="Duo Riso" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/velhotePraia.jpg`} alt="Velhote Praia" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/guilhermePonte.jpg`} alt="Guilherme Collection" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/ornatos.jpg`} alt="Ornatos" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/25abrilinimigo.jpg`} alt="25 de Abril Inimigo" />
        </div>
    </div>
  
</BaseLayout>