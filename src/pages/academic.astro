---
import BaseLayout from '../layouts/BaseLayout.astro';
import CollectionCard from '../components/CollectionCard.astro';

const estudanteImages = [
  {
    src: `${import.meta.env.BASE_URL}/images/protestoEstudantebw.webp`,
    alt: "Manifestação Estudante 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/estado_falha.webp`,
    alt: "Manifestação Estudante 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/protesto1.webp`,
    alt: "Manifestação Estudante 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/arrebentar.webp`,
    alt: "Manifestação Estudante 2026"
  }
];

const cortejo26Images = [
  {
    src: `${import.meta.env.BASE_URL}/images/IMG_4284.webp`,
    alt: "Cortejo 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/IMG_4367.webp`,
    alt: "Cortejo 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/cortejoCarroEletro.webp`,
    alt: "Cortejo 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/IMG_4256.webp`,
    alt: "Cortejo 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/IMG_4195.webp`,
    alt: "Cortejo 2026"
  },
  {
    src: `${import.meta.env.BASE_URL}/images/IMG_4229.webp`,
    alt: "Cortejo 2026"
  }
];

---

<BaseLayout>
    <div class="academico">
        <div class="title">
            <h2>Académico</h2>
        </div>
        <div class="gallery">

          <CollectionCard title="Manifestação Estudante 2026" images={estudanteImages} />
          <CollectionCard title="Cortejo 2026" images={cortejo26Images} />

        </div>
    </div>
</BaseLayout>