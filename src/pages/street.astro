---
import BaseLayout from '../layouts/BaseLayout.astro';
import PhotoCard from '../components/PhotoCard.astro';
---

<BaseLayout>
    <div class="street">
        <div class="title">
            <h2>Street Photography</h2>
        </div>
        <div class="gallery">
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/alwaysrush.jpg`} alt="Always in a Rush" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/senhorFonte.jpg`} alt="Senhor Fonte" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/velhotePraia.jpg`} alt="Velhote Praia" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/feira_caldas.jpg`} alt="Trocas" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/estacaocentral_ams.jpg`} alt="Train doesn't wait" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/loneliness.jpg`} alt="Loneliness" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/parapente.jpg`} alt="kitesurf" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/senhora_filha_metro.jpg`} alt="Exploration" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/passeio_cao_ams.jpg`} alt="Dog world" />
            <PhotoCard src={`${import.meta.env.BASE_URL}/images/FilipeSerafim_ConcursoLEICA.jpg`} alt="Culture" />
        </div>
    </div>
</BaseLayout>