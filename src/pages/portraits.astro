---
import BaseLayout from '../layouts/BaseLayout.astro';
import CollectionCard from '../components/CollectionCard.astro';

const guilhermeImages = [
  {
    src: "/images/guilhermeGrade.jpg",
    alt: "Guilherme Collection"
  },
  {
    src: "/images/guilhermePonte.jpg",
    alt: "Guilherme Collection"
  },
  {
    src: "/images/guilherme_telemovel.jpg",
    alt: "Guilherme Collection"
  }
];

---

<BaseLayout>
  <div class="gallery">

    <CollectionCard
      title="Guilherme Collection"
      images={guilhermeImages}
    />

  </div>
</BaseLayout>